generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum InstitutionType {
  PRIMARY_SECONDARY
  UNIVERSITY
}

enum Role {
  TEACHER
  ADMIN
  HEAD_TEACHER
}

enum ExamStatus {
  DRAFT
  ACTIVE
  GRADING
  COMPLETED
}

enum QuestionType {
  SHORT_ANSWER
  ESSAY
  MULTIPLE_CHOICE
  STRUCTURED
  PRACTICAL
}

enum ScoringType {
  POSITIVE
  NEGATIVE
}

enum FileType {
  PDF
  IMAGE
  IMAGES
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubmissionStatus {
  UPLOADED
  OCR_PROCESSING
  READY
  GRADING
  GRADED
  REVIEWED
}

enum AiModel {
  OPENAI
  ANTHROPIC
  GEMINI
}

enum ConfidenceLevel {
  HIGH
  LOW
}

// ─── Models ─────────────────────────────────────────────────

model Profile {
  id                 String          @id @default(uuid())
  email              String          @unique
  fullName           String
  avatarUrl          String?
  institutionType    InstitutionType?
  institutionName    String?
  role               Role            @default(TEACHER)
  onboardingComplete Boolean         @default(false)
  tourComplete       Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  exams   Exam[]
  rubrics Rubric[]
  grades  Grade[]   @relation("GradedBy")

  @@map("profiles")
}

model Exam {
  id              String     @id @default(uuid())
  userId          String
  title           String
  description     String?
  subject         String
  level           String
  curriculum      String     @default("Uganda")
  totalMarks      Int
  status          ExamStatus @default(DRAFT)
  gradesPublished Boolean    @default(false)
  submissionCount Int        @default(0)
  gradedCount     Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user        Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   Question[]
  rubrics     Rubric[]
  submissions Submission[]

  @@map("exams")
}

model Question {
  id             String       @id @default(uuid())
  examId         String
  questionNumber Int
  questionText   String
  questionType   QuestionType @default(SHORT_ANSWER)
  maxMarks       Int
  modelAnswer    String?
  markingNotes   String?
  createdAt      DateTime     @default(now())

  exam             Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  aiGradingResults AiGradingResult[]
  grades           Grade[]

  @@unique([examId, questionNumber])
  @@map("questions")
}

model Rubric {
  id              String      @id @default(uuid())
  examId          String?
  userId          String
  name            String
  description     String?
  isTemplate      Boolean     @default(false)
  level           String?
  subject         String?
  scoringType     ScoringType @default(POSITIVE)
  allowNegative   Boolean     @default(false)
  totalPoints     Int
  criteria        Json
  gradeBoundaries Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  exam Exam?   @relation(fields: [examId], references: [id], onDelete: SetNull)
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rubrics")
}

model Submission {
  id               String           @id @default(uuid())
  examId           String
  studentName      String?
  studentNumber    String?
  fileUrl          String
  fileType         FileType         @default(PDF)
  originalFilename String
  ocrText          String?
  ocrStatus        OcrStatus        @default(PENDING)
  ocrConfidence    Float?
  submissionNumber Int
  status           SubmissionStatus @default(UPLOADED)
  isReviewed       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  exam             Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  aiGradingResults AiGradingResult[]
  grades           Grade[]

  @@map("submissions")
}

model AiGradingResult {
  id           String   @id @default(uuid())
  submissionId String
  questionId   String
  aiModel      AiModel
  score        Float
  maxScore     Float
  feedback     String?
  deductions   Json?
  confidence   Float?
  rawResponse  Json?
  latencyMs    Int?
  error        String?
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId, aiModel])
  @@map("ai_grading_results")
}

model Grade {
  id              String           @id @default(uuid())
  submissionId    String
  questionId      String
  score           Float
  maxScore        Float
  feedback        String?
  deductions      Json?
  aiAveragedScore Float?
  aiConfidence    Float?
  confidenceLevel ConfidenceLevel?
  humanAdjusted   Boolean          @default(false)
  isReviewed      Boolean          @default(false)
  gradedById      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  gradedBy   Profile?   @relation("GradedBy", fields: [gradedById], references: [id], onDelete: SetNull)

  @@unique([submissionId, questionId])
  @@map("grades")
}
